<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/light_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="100dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/adv_info"
            android:textColor="@color/text_gray"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <include
                android:id="@+id/cardActiveCases"
                layout="@layout/layout_stat_card_compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp" />

            <include
                android:id="@+id/cardNextHearings"
                layout="@layout/layout_stat_card_compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp" />

            <include
                android:id="@+id/cardDisposed"
                layout="@layout/layout_stat_card_compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/todays_cause_list"
            android:textColor="@color/dark_blue"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <include android:id="@+id/item1" layout="@layout/layout_hearing_card" />
        <include android:id="@+id/item2" layout="@layout/layout_hearing_card" />

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/upcoming_hearings"
            android:textColor="@color/dark_blue"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <include android:id="@+id/upcoming1" layout="@layout/layout_upcoming_compact" />
        <include android:id="@+id/upcoming2" layout="@layout/layout_upcoming_compact" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
