<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_gray">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/shimmerCaseNo"
            android:layout_width="120dp"
            android:layout_height="20dp"
            android:background="@color/light_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/shimmerSync"
            android:layout_width="180dp"
            android:layout_height="12dp"
            android:layout_marginTop="8dp"
            android:background="@color/light_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/shimmerCaseNo" />

        <View
            android:id="@+id/shimmerClient"
            android:layout_width="140dp"
            android:layout_height="16dp"
            android:layout_marginTop="16dp"
            android:background="@color/light_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/shimmerSync" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/shimmerClient">

            <View android:layout_width="32dp" android:layout_height="32dp" android:background="@color/light_gray" android:backgroundTint="@null"/>
            <View android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_gravity="center" android:background="@color/light_gray" android:layout_marginHorizontal="8dp"/>
            <View android:layout_width="32dp" android:layout_height="32dp" android:background="@color/light_gray"/>
            <View android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:layout_gravity="center" android:background="@color/light_gray" android:layout_marginHorizontal="8dp"/>
            <View android:layout_width="32dp" android:layout_height="32dp" android:background="@color/light_gray"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
