<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/primary_navy"
            app:title="Case Details"
            app:titleCentered="true"
            app:titleTextColor="@color/primary_navy" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Case Summary Header -->
            <TextView
                android:id="@+id/tvCaseNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/primary_navy"
                android:textSize="26sp"
                tools:text="OS 123/2023" />

            <TextView
                android:id="@+id/tvCourtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_gray"
                android:textSize="14sp"
                tools:text="District Court, Madurai" />

            <!-- Next Hearing Highlight Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="NEXT HEARING"
                        android:textColor="@color/accent_gold"
                        android:textSize="11sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvNextHearingDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        tools:text="24 Feb 2024" />

                    <TextView
                        android:id="@+id/tvPurpose"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        tools:text="Purpose: For Evidence" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Case Progress Timeline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-medium"
                android:text="CASE PROGRESS"
                android:textColor="@color/accent_gold"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <include android:id="@+id/stepFiled" layout="@layout/layout_timeline_step" />
                    <include android:id="@+id/stepHearing" layout="@layout/layout_timeline_step" />
                    <include android:id="@+id/stepEvidence" layout="@layout/layout_timeline_step" />
                    <include android:id="@+id/stepArgument" layout="@layout/layout_timeline_step" />
                    <include android:id="@+id/stepJudgment" layout="@layout/layout_timeline_step" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Client & Team Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Client Info -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="CLIENT INFORMATION"
                        android:textColor="@color/accent_gold"
                        android:textSize="11sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvClientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary_navy"
                        android:textSize="17sp"
                        tools:text="Rajesh Kumar" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvNotificationPhone"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/text_gray"
                            android:textSize="14sp"
                            app:drawableStartCompat="@drawable/ic_phone"
                            android:drawablePadding="8dp"
                            app:drawableTint="@color/text_gray"
                            tools:text="+91 9876543210" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUpdateNotificationPhone"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:textSize="12sp"
                            android:textColor="@color/primary_navy"
                            android:padding="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/juniorDivider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/border_gray"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Assigned Juniors Summary -->
                    <TextView
                        android:id="@+id/tvAssignedJuniorSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/status_green"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone"
                        tools:text="Junior: Adv. John Doe +1 more"
                        tools:visibility="visible" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Team Management Full List -->
            <TextView
                android:id="@+id/tvJuniorLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-medium"
                android:text="TEAM MANAGEMENT"
                android:textColor="@color/accent_gold"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutAssignedJunior"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddJunior"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:text="Assign Junior Advocate"
                android:textColor="@color/primary_navy"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border_gray" />

            <!-- Purpose / Notes History -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-medium"
                android:text="PURPOSE / NOTES HISTORY"
                android:textColor="@color/accent_gold"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/layout_task_item" />

            <TextView
                android:id="@+id/tvNoNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="32dp"
                android:text="No notes recorded yet."
                android:textColor="@color/text_gray"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddNote"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/primary_navy"
                android:text="Add New Note"
                android:textColor="@color/white"
                app:cornerRadius="12dp"
                app:elevation="2dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="60dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading State Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:clickable="true"
        android:focusable="true"
        android:visibility="visible">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            app:indicatorColor="@color/primary_navy" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
